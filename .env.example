# ──────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# From your Supabase project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Session ───────────────────────────────────────────────────
# How long sessions last in hours (default: 8)
SESSION_TTL_HOURS=8

# ── CSRF ──────────────────────────────────────────────────────
# Random 64-character string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=replace_with_64_char_random_hex_string

# ── Google Sheets ─────────────────────────────────────────────
# No API key or Google Cloud account needed.
# For each sheet: Share → General access → "Anyone with the link" → Viewer
# No env vars required for Google Sheets.

# ── Upstash Redis (Rate Limiting) ─────────────────────────────
# Create a free Redis database at upstash.com.
# Required for rate limiting to work across Vercel instances.
# If omitted, rate limiting is DISABLED (development only).
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Cron Job Secret ───────────────────────────────────────────
# Protects the /api/cron/cleanup endpoint.
# Set in Vercel dashboard → Environment Variables.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace_with_random_secret
